      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Morning Briefing sends you a notification each morning with a summary of your day's schedule. Set the time in Settings → Preferences → Notifications → Morning Briefing. Premium feature."
          }
