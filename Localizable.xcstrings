    },
    "faq_data_where_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All your data is stored locally on your device. Structify does not have any servers — your events, habits, and logs never leave your iPhone unless you choose to export them."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tất cả dữ liệu của bạn được lưu trực tiếp trên thiết bị. Structify không có máy chủ — các sự kiện, thói quen và nhật ký của bạn sẽ không rời khỏi iPhone trừ khi bạn chủ động xuất dữ liệu."
          }
        }
      }
    },
    "faq_data_where_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where is my data stored?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dữ liệu của tôi được lưu ở đâu?"
          }
        }
      }
    },
    "faq_delete_app_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All local data will be permanently deleted. We strongly recommend exporting a backup before uninstalling. If you have iCloud Backup enabled on your iPhone, some data may be included in your device backup."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toàn bộ dữ liệu cục bộ sẽ bị xoá vĩnh viễn. Chúng tôi khuyến nghị bạn sao lưu trước khi gỡ ứng dụng. Nếu bạn bật iCloud Backup, một phần dữ liệu có thể được lưu trong bản sao lưu thiết bị."
          }
        }
      }
    },
    "faq_delete_app_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What happens if I delete the app?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Điều gì xảy ra nếu tôi xoá ứng dụng?"
          }
        }
      }
    },
    "faq_event_vs_habit_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Events are one-off or recurring time blocks — like meetings, workouts, or study sessions. They have a start time and an optional duration. Habits are recurring tasks you want to build consistency with — they show a completion ring and track your streaks over time."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Event là các khung thời gian cho hoạt động cụ thể như họp, tập luyện hoặc học tập. Chúng có giờ bắt đầu và có thể có thời lượng. Habit là các hoạt động lặp lại nhằm xây dựng sự nhất quán, hiển thị vòng hoàn thành và theo dõi chuỗi streak theo thời gian."
          }
        }
      }
    },
    "faq_event_vs_habit_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What's the difference between an Event and a Habit?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sự khác nhau giữa Event và Habit là gì?"
          }
        }
      }
    },
    "faq_export_csv_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yes — go to Settings → Preferences → Stats & Data → Export CSV. This exports your last 90 days of events and habits with completion status into a CSV file that opens in Numbers, Excel, or Google Sheets."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Có — vào Cài đặt → Tùy chọn → Thống kê & Dữ liệu → Xuất CSV. Tính năng này xuất 90 ngày gần nhất gồm sự kiện và thói quen kèm trạng thái hoàn thành thành file CSV, có thể mở bằng Numbers, Excel hoặc Google Sheets."
          }
        }
      }
    },
    "faq_export_csv_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can I export my history to a spreadsheet?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tôi có thể xuất dữ liệu ra bảng tính không? "
          }
        }
      }
    },
