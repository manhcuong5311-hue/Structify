    "faq_premium_refund_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Refunds are handled by Apple. Visit reportaproblem.apple.com, sign in with your Apple ID, find the Structify purchase, and submit a refund request. Apple typically processes refunds within a few days."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Việc hoàn tiền được xử lý bởi Apple. Truy cập reportaproblem.apple.com, đăng nhập bằng Apple ID, tìm giao dịch Structify và gửi yêu cầu hoàn tiền. Apple thường xử lý trong vài ngày."
          }
        }
      }
    },
    "faq_premium_refund_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can I get a refund?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tôi có thể hoàn tiền không?"
          }
        }
      }
    },
    "faq_premium_restore_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Account → Restore Purchase, or open the Premium screen and tap Restore Purchase at the bottom. As long as you're signed in with the same Apple ID, your purchase will be restored instantly."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vào Cài đặt → Tài khoản → Khôi phục giao dịch, hoặc mở màn hình Premium và nhấn Khôi phục giao dịch ở cuối. Chỉ cần đăng nhập cùng Apple ID, giao dịch sẽ được khôi phục ngay lập tức."
          }
        }
      }
    },
    "faq_premium_restore_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How do I restore my purchase on a new device?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Làm sao để khôi phục Premium trên thiết bị mới?"
          }
        }
      }
    },
    "faq_premium_subscription_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No — Structify Premium is a one-time purchase of $4.99 USD. You pay once and own it forever. There are no monthly fees, no renewals, and no surprise charges."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Không — Structify Premium là gói mua một lần với giá $4.99 USD. Bạn chỉ trả một lần và sử dụng vĩnh viễn. Không có phí hàng tháng, không gia hạn, không phát sinh chi phí."
          }
        }
      }
    },
    "faq_premium_subscription_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is Premium a subscription?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Premium có phải trả phí hàng tháng không?"
          }
        }
