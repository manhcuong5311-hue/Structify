    "faq_habits_accumulative_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An accumulative habit has a numeric target — like drinking 2,000 ml of water or walking 10,000 steps. Each tap adds your increment (e.g. +250 ml). A progress ring fills as you go, completing when you hit your target."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thói quen tích lũy có mục tiêu dạng số — ví dụ uống 2.000 ml nước hoặc đi 10.000 bước. Mỗi lần nhấn sẽ cộng thêm một lượng tăng (ví dụ +250 ml). Vòng tiến độ sẽ dần đầy cho đến khi đạt mục tiêu."
          }
        }
      }
    },
    "faq_habits_accumulative_q" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is an Accumulative habit?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Thói quen tích lũy là gì?"
          }
        }
      }
    },
    "faq_habits_mark_done_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the circle button on the right side of any habit row. For binary habits it toggles complete/incomplete. For accumulative habits, each tap adds your set increment — keep tapping until you reach the target."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nhấn vào nút hình tròn ở bên phải của hàng thói quen. Với thói quen nhị phân, mỗi lần nhấn sẽ chuyển giữa hoàn thành và chưa hoàn thành. Với thói quen tích lũy, mỗi lần nhấn sẽ cộng thêm một lượng tăng đã đặt cho đến khi đạt mục tiêu."
          }
        }
      }
    },
    "faq_habits_mark_done_q" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How do I mark a habit as done?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Làm sao để đánh dấu thói quen đã hoàn thành?"
          }
        }
      }
    },
    "faq_habits_repeat_options_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can set a habit to repeat Every Day, on Weekdays only, on specific days of the week, for a fixed range (1 week or 1 month), or just once on a single day."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có thể đặt thói quen lặp lại mỗi ngày, chỉ vào ngày trong tuần, chọn các ngày cụ thể trong tuần, trong một khoảng thời gian cố định (1 tuần hoặc 1 tháng), hoặc chỉ một lần vào một ngày duy nhất."
          }
        }
      }
    },
    "faq_habits_repeat_options_q" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What repeat options are available for habits?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Có những tùy chọn lặp lại nào cho thói quen?"
          }
        }
      }
    },
    "faq_habits_streak_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yes — open the Stats tab (chart icon in the tab bar) to see your current streak, best streak, and a 30-day completion calendar for each habit. You can adjust the streak threshold in Settings → Preferences."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Có — mở tab Stats (biểu tượng biểu đồ ở thanh tab) để xem streak hiện tại, streak tốt nhất và lịch hoàn thành 30 ngày cho từng thói quen. Bạn có thể điều chỉnh ngưỡng streak trong Settings → Preferences."
          }
        }
      }
