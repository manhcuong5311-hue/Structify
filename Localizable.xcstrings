    "faq_backup_how_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Preferences → Stats & Data → Export Backup. This creates a JSON file you can save to Files, iCloud Drive, or share anywhere. To restore, tap Restore Backup and select your backup file."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Vào Cài đặt → Tùy chọn → Thống kê & Dữ liệu → Xuất bản sao lưu. Thao tác này tạo file JSON mà bạn có thể lưu vào Tệp, iCloud Drive hoặc chia sẻ. Để khôi phục, chọn Khôi phục bản sao lưu và chọn file của bạn."
          }
        }
      }
    },
