    "faq_create_event_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the + button at the bottom right of the main screen. You can create a timed Event (with a start time and duration) or a Habit (recurring daily task). Fill in the title, pick an icon and color, then tap Create."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nhấn nút + ở góc dưới bên phải màn hình chính. Bạn có thể tạo Event có thời gian (giờ bắt đầu và thời lượng) hoặc Habit (thói quen lặp lại hằng ngày). Nhập tiêu đề, chọn icon và màu, sau đó nhấn Create."
          }
        }
      }
    },
    "faq_create_event_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How do I create my first event?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Làm thế nào để tạo sự kiện đầu tiên?"
          }
        }
      }
    },
    "faq_customization_accent_color_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Preferences → Appearance → Accent Color. Choose from the preset palette or use the color picker to set any custom color. The accent color applies to the timeline line, buttons, and highlights throughout the app."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vào Settings → Preferences → Appearance → Accent Color. Bạn có thể chọn từ bảng màu có sẵn hoặc dùng color picker để đặt màu tùy chỉnh. Màu accent sẽ áp dụng cho đường timeline, các nút và điểm nhấn trong toàn bộ ứng dụng."
          }
        }
      }
    },
    "faq_customization_accent_color_q" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How do I change the app accent color?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Làm sao để thay đổi màu accent của ứng dụng?"
          }
        }
      }
    },
    "faq_customization_density_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Timeline Density controls how much vertical space is allocated between events. Compact fits more on screen, while Comfortable adds more breathing room. Adjust it in Settings → Preferences → Appearance."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Timeline Density điều chỉnh khoảng cách dọc giữa các sự kiện. Chế độ Compact hiển thị nhiều sự kiện hơn trên màn hình, còn Comfortable tạo khoảng cách rộng rãi hơn. Bạn có thể thay đổi trong Settings → Preferences → Appearance."
          }
        }
      }
    },
    "faq_customization_density_q" : {
