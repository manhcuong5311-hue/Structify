    "faq_notifications_evening_review_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evening Review sends you a nightly reminder to reflect on your day and plan tomorrow. Set your preferred time in Settings → Preferences → Notifications → Evening Review. Premium feature."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evening Review gửi thông báo vào buổi tối để nhắc bạn nhìn lại ngày hôm nay và chuẩn bị cho ngày mai. Bạn có thể đặt thời gian trong Settings → Preferences → Notifications → Evening Review. Đây là tính năng Premium."
          }
        }
      }
    },
