        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Timeline Density controls how much vertical space is allocated between events. Compact fits more on screen, while Comfortable adds more breathing room. Adjust it in Settings → Preferences → Appearance."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Timeline Density điều chỉnh khoảng cách dọc giữa các sự kiện. Chế độ Compact hiển thị nhiều sự kiện hơn trên màn hình, còn Comfortable tạo khoảng cách rộng rãi hơn. Bạn có thể thay đổi trong Settings → Preferences → Appearance."
          }
