          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Structify là gì?"
          }
        }
      }
    },
    "faq_timeline_gap_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When there's free time between two events, Structify shows a subtle message like \\\"A quiet hour — worth filling\\\". Tap it to quickly create a new event in that gap, pre-filled with the right start time."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Khi có thời gian trống giữa hai sự kiện, Structify sẽ hiển thị một thông báo nhẹ như \\\"Một giờ yên tĩnh — có thể tận dụng\\\". Nhấn vào đó để nhanh chóng tạo sự kiện mới trong khoảng trống này với thời gian bắt đầu được điền sẵn."
          }
        }
      }
    },
    "faq_timeline_gap_q" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What does the gap message between events mean?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thông báo khoảng trống giữa các sự kiện nghĩa là gì?"
          }
        }
      }
    },
    "faq_timeline_morning_night_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These are system events that define your day's boundaries. Morning Start is your wake time and Night Reset is your sleep time. All other events are constrained within this window. You can adjust both times in Settings → Preferences → Schedule."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Đây là các sự kiện hệ thống xác định giới hạn của một ngày. Morning Start là thời gian bạn thức dậy và Night Reset là thời gian bạn đi ngủ. Tất cả sự kiện khác sẽ nằm trong khoảng này. Bạn có thể chỉnh hai thời gian này trong Settings → Preferences → Schedule."
          }
        }
      }
    },
    "faq_timeline_morning_night_q" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What are Morning Start and Night Reset?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Morning Start và Night Reset là gì?"
          }
        }
      }
    },
    "faq_timeline_move_event_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Long press on any event until it lifts (you'll feel a haptic). Then drag it up or down to the new time slot. Release to drop it. For recurring events, you'll be asked whether to move just today or all days."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nhấn giữ một sự kiện cho đến khi nó nổi lên (bạn sẽ cảm nhận rung nhẹ). Sau đó kéo lên hoặc xuống đến khung giờ mới và thả ra. Với sự kiện lặp lại, bạn sẽ được hỏi chỉ di chuyển hôm nay hay tất cả các ngày."
          }
        }
      }
    },
    "faq_timeline_move_event_q" : {
      "localizations" : {
