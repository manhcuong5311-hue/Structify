    "faq_customization_accent_color_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Preferences → Appearance → Accent Color. Choose from the preset palette or use the color picker to set any custom color. The accent color applies to the timeline line, buttons, and highlights throughout the app."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vào Settings → Preferences → Appearance → Accent Color. Bạn có thể chọn từ bảng màu có sẵn hoặc dùng color picker để đặt màu tùy chỉnh. Màu accent sẽ áp dụng cho đường timeline, các nút và điểm nhấn trong toàn bộ ứng dụng."
