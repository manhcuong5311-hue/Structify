    "faq_data_where_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All your data is stored locally on your device. Structify does not have any servers — your events, habits, and logs never leave your iPhone unless you choose to export them."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tất cả dữ liệu của bạn được lưu trực tiếp trên thiết bị. Structify không có máy chủ — các sự kiện, thói quen và nhật ký của bạn sẽ không rời khỏi iPhone trừ khi bạn chủ động xuất dữ liệu."
          }
        }
      }
    },
    "faq_data_where_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where is my data stored?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dữ liệu của tôi được lưu ở đâu?"
          }
        }
      }
    },
    "faq_delete_app_answer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All local data will be permanently deleted. We strongly recommend exporting a backup before uninstalling. If you have iCloud Backup enabled on your iPhone, some data may be included in your device backup."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toàn bộ dữ liệu cục bộ sẽ bị xoá vĩnh viễn. Chúng tôi khuyến nghị bạn sao lưu trước khi gỡ ứng dụng. Nếu bạn bật iCloud Backup, một phần dữ liệu có thể được lưu trong bản sao lưu thiết bị."
          }
        }
      }
    },
    "faq_delete_app_question" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What happens if I delete the app?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
