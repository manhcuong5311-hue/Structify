    "faq_notifications_not_receiving_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Make sure notifications are enabled in both Structify (Settings → Notifications) and in iOS Settings → Structify → Notifications. Also check that Focus modes aren't blocking the app."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hãy đảm bảo thông báo được bật trong cả Structify (Settings → Notifications) và trong iOS Settings → Structify → Notifications. Ngoài ra hãy kiểm tra xem các chế độ Focus có đang chặn thông báo của ứng dụng không."
