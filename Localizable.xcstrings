          "stringUnit" : {
            "state" : "translated",
            "value" : "Làm sao để di chuyển sự kiện trên timeline?"
          }
        }
      }
    },
    "faq_timeline_resize_event_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Long press an event to enter hold mode, then drag the end time (shown at the bottom of the event pill) up or down to adjust the duration. The duration preview updates in real time as you drag."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nhấn giữ sự kiện để vào chế độ chỉnh sửa, sau đó kéo phần cuối thời gian của sự kiện (ở đáy khối sự kiện) lên hoặc xuống để thay đổi thời lượng. Thời lượng sẽ cập nhật theo thời gian thực khi bạn kéo."
          }
        }
      }
    },
