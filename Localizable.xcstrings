    "faq_notifications_event_setup_a" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Notifications and enable the global toggle. You can set a lead time (how many minutes before an event you're notified) and toggle notifications on or off for individual event types."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vào Settings → Notifications và bật công tắc chính. Bạn có thể đặt thời gian nhắc trước (bao nhiêu phút trước khi sự kiện bắt đầu) và bật hoặc tắt thông báo cho từng loại sự kiện."
